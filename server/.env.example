# URETIM (production) temel ayarlar
NODE_ENV=production
API_HOST=127.0.0.1
API_PORT=8787
CLIENT_URL=https://ALANADI
RESET_LINK_BASE_URL=https://ALANADI
CORS_ALLOWED_ORIGINS=https://ALANADI

# Origin gondermeyen native istemcilere izin verilsin mi?
CORS_ALLOW_NO_ORIGIN=true
# /api/health/system ve /api/health/backup endpointleri icin zorunlu guvenlik anahtari.
HEALTHCHECK_TOKEN=CHANGE_ME_HEALTHCHECK_TOKEN
# Eski websocket token query param destegi (production icin false onerilir).
WS_ALLOW_QUERY_TOKEN=false

MAX_ACCOUNTS_PER_SCOPE=2
# true ise hesap sadece kayit oldugu public IP ile giris yapabilir.
ENFORCE_REGISTER_IP_ON_LOGIN=false
# true ise farkli Wi-Fi agina geciste (farkli subnet) giris engellenir.
ENFORCE_REGISTER_SUBNET_ON_LOGIN=false
RESET_TOKEN_TTL_MINUTES=3
GEO_STALE_ALLOW_MS=86400000

# Veritabani dosyasini proje disinda kalici bir dizine tasiman onerilir.
# Ornek (Windows): DB_FILE_PATH=C:/TicarNetData/db.json
# Ornek (Linux):   DB_FILE_PATH=/var/lib/ticarnet/db.json
DB_FILE_PATH=
DB_AUTO_BACKUP_ENABLED=false
DB_AUTO_BACKUP_INTERVAL_MINUTES=10
# Tek dosya yedek modu: db-rolling.json her yazmada guncellenir.
DB_SINGLE_BACKUP_MODE=true
DB_ROLLING_BACKUP_ENABLED=true
# Bos birakirsan DB_FILE_PATH yanina backups/db-rolling.json yazilir.
DB_ROLLING_BACKUP_FILE_PATH=
DB_AUTO_BACKUP_KEEP_COUNT=1
DB_PREVENT_FULL_USER_WIPE=true
DB_HARD_STOP_ON_EMPTY_WRITE=true
DB_ALLOW_EMPTY_USERS_WRITE=false
API_SINGLE_INSTANCE_LOCK_ENABLED=true
# Bos birakirsan DB dizininde api.lock olusturulur.
API_SINGLE_INSTANCE_LOCK_FILE_PATH=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=240
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=40
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=12
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=120
REQUEST_METRICS_ENABLED=true
REQUEST_METRICS_TOP_ROUTES=12
CRASH_LOG_FILE_PATH=
ACCOUNT_DELETION_ENABLED=false

# JWT ayarlari
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES=30d
# JWT_EXPIRES=none yazarsan token suresi olmaz (manuel cikis yapilana kadar gecerli olur).
# true => yeni giris eski cihazdaki oturumu kapatir, false => coklu cihaz oturumu serbest
SINGLE_SESSION_ENFORCED=false
ADMIN_EMAILS=mustafaard76@gmail.com
ADMIN_PANEL_OWNER_EMAIL=mustafaard76@gmail.com
ADMIN_DIAMOND_GRANT_ENABLED=true

# SMTP (destek taleplerini e-posta ile iletmek icin, opsiyonel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mustafaard76@gmail.com
# Google hesabinda 2 adimli dogrulama acik olmali, buraya Gmail App Password girilmeli.
SMTP_APP_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD
# Geriye donuk destek:
SMTP_PASS=
MAIL_FROM="TicarNet Online <mustafaard76@gmail.com>"
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# Destek talepleri icin hedef e-posta
SUPPORT_INBOX_EMAIL=mustafaard76@gmail.com

# Firebase Authentication (tumu e-posta domainleri + sifre reset)
FIREBASE_AUTH_ENABLED=true
# Firebase Console > Project Settings > Web API Key
FIREBASE_WEB_API_KEY=CHANGE_ME_FIREBASE_WEB_API_KEY

# Firebase Cloud Messaging (gercek mobil push)
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC123...\n-----END PRIVATE KEY-----\n"
# Alternatif olarak tum service account JSON'unu tek satir string olarak verebilirsin:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
# Ya da dosya yolu verebilirsin:
# FIREBASE_SERVICE_ACCOUNT_FILE=server/firebase-service-account.json
